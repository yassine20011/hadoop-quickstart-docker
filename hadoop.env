# Hadoop config overrides loaded by docker-compose services.
#
# Naming rule used by bde2020/hadoop-base entrypoint:
#   <PREFIX>_a_b_c    -> a.b.c
# Prefixes:
#   CORE_CONF_   => core-site.xml
#   HDFS_CONF_   => hdfs-site.xml
#   YARN_CONF_   => yarn-site.xml
#   MAPRED_CONF_ => mapred-site.xml
#
# Common tunables (edit as needed):
HDFS_CONF_dfs_replication=1
HDFS_CONF_dfs_blocksize=134217728
# HDFS_CONF_dfs_namenode_handler_count=10
# YARN_CONF_yarn_scheduler_minimum__allocation__mb=256
# YARN_CONF_yarn_scheduler_maximum__allocation__mb=2048
# MAPRED_CONF_mapreduce_map_memory_mb=512
# MAPRED_CONF_mapreduce_reduce_memory_mb=512
